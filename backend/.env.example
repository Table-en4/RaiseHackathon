# Exa web-research API key — https://dashboard.exa.ai
# Without it, the service still runs on the seed dataset + stored DB rows.
EXA_API_KEY=
# Timeout for Exa calls on the advisory path (seconds). /api/refresh always
# uses a long timeout regardless — pre-warm demo lots with it.
EXA_TIMEOUT_SEC=2.5

# eBay Browse API (official) — https://developer.ebay.com
# Client-credentials OAuth: only the app keys are needed, no user login.
# Powers /api/asking (live ASKING prices — sold prices are not available
# to standard keys). Without them, /api/asking returns an empty list.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Marketplace for searches (default EBAY_FR).
EBAY_MARKETPLACE_ID=EBAY_FR

# SQLite file path for stored market sales (default: market.db in backend/).
# To use Neon Postgres instead, see db.py (DATABASE_URL support).
MARKET_DB_PATH=market.db

# Port the Flask API listens on.
PORT=5001
