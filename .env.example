# Public
PUBLIC_URL=https://gavel.example.com
NODE_ENV=development

# LLM (in-cluster preferred)
LLM_URL=http://localhost:11434
LLM_MODEL=llama3.2
USE_EXTERNAL_LLM=false

# External LLM fallback (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Admin demo trigger
ADMIN_TOKEN=dev-admin-token-change-me

# Optional persistence
DATABASE_URL=
REDIS_URL=

# Local tunnel fallback (optional)
CLOUDFLARE_TUNNEL_TOKEN=
