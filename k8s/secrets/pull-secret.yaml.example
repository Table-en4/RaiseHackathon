# Template only — or use Paris init.sh --deploy-secret gavel
apiVersion: v1
kind: Secret
metadata:
  name: gavel-pull-secret
  namespace: gavel
type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: |
    {
      "auths": {
        "<hackathon-registry>": {
          "username": "<user>",
          "password": "<password>",
          "auth": "<base64-user:password>"
        }
      }
    }
