# Template only — create real secret at deploy time (never commit real values):
# kubectl create secret generic gavel-infra-secrets --namespace=gavel --from-literal=CLOUDFLARE_TUNNEL_TOKEN=<token>
apiVersion: v1
kind: Secret
metadata:
  name: gavel-infra-secrets
  namespace: gavel
type: Opaque
stringData:
  CLOUDFLARE_TUNNEL_TOKEN: ""
