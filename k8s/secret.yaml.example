# Template only — create real secret at deploy time:
# kubectl create secret generic gavel-secrets --namespace=gavel --from-env-file=.env.production
apiVersion: v1
kind: Secret
metadata:
  name: gavel-secrets
  namespace: gavel
type: Opaque
stringData:
  ADMIN_TOKEN: change-me-before-deploy
  OPENAI_API_KEY: ""
  DATABASE_URL: ""
  REDIS_URL: ""
